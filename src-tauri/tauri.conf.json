{
  "build": {
    "distDir": "../ui",
    "devPath": "../ui"
  },
  "package": {
    "productName": "春戊NEXT - 桌面客户端",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "withGlobalTauri": true,
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "org.cwu.next.portal",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "春戊NEXT - 桌面客户端",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}
